# ─────────────────────────────────────────────────────────────────────────────
# .env.example – copy to .env and fill in real values.
# NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (AWS RDS – PostgreSQL) ──────────────────────────────────────────
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=5432
DB_NAME=urlshortener
DB_USERNAME=dbuser
DB_PASSWORD=CHANGE_ME_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secure random secret: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_replace_with_a_long_random_base64_string
JWT_EXPIRATION_MS=86400000

# ── Application ───────────────────────────────────────────────────────────────
SERVER_PORT=8080

# Fully-qualified base URL used when building short URLs in responses.
# Example: https://short.yourdomain.com
APP_BASE_URL=http://localhost:8080

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of React frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
