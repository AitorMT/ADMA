# URL of the Spring Boot backend API.
# Local development:  http://localhost:8080
# Docker Compose:     http://backend:8080  (service name resolution)
# AWS ECS Fargate:    https://api.yourdomain.com  (ALB/CloudFront URL)
VITE_API_BASE_URL=http://localhost:8080
